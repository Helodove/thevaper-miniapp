VITE_API_BASE=https://api.thevaper.bot/v1

# Telegram Bot (для динамического баннера)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=       # числовой ID канала, например -1001234567890
TELEGRAM_WEBHOOK_SECRET=   # любая строка-секрет, например uuid4

# Supabase (для хранения последнего поста)
SUPABASE_URL=              # https://<project>.supabase.co
SUPABASE_SERVICE_KEY=      # service_role ключ (не anon!), из Supabase → Settings → API
